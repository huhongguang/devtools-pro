{
  "searchPlaceholder": "搜索状态码...",
  "filterAll": "全部",
  "selectPrompt": "选择状态码查看详情",
  "groups": {
    "1xx": "信息",
    "2xx": "成功",
    "3xx": "重定向",
    "4xx": "客户端错误",
    "5xx": "服务器错误"
  },
  "codes": {
    "100": {
      "phrase": "Continue",
      "description": "服务器已收到请求头，客户端应继续发送请求体。"
    },
    "101": {
      "phrase": "Switching Protocols",
      "description": "服务器正在切换协议。"
    },
    "103": {
      "phrase": "Early Hints",
      "description": "在最终 HTTP 消息之前返回部分响应头。"
    },
    "200": {
      "phrase": "OK",
      "description": "请求成功。"
    },
    "201": {
      "phrase": "Created",
      "description": "请求已完成，新资源已创建。"
    },
    "202": {
      "phrase": "Accepted",
      "description": "请求已被接受处理，但处理尚未完成。"
    },
    "204": {
      "phrase": "No Content",
      "description": "服务器成功处理请求，但不返回任何内容。"
    },
    "206": {
      "phrase": "Partial Content",
      "description": "服务器仅返回资源的一部分。"
    },
    "301": {
      "phrase": "Moved Permanently",
      "description": "请求的资源已永久移到新 URL。"
    },
    "302": {
      "phrase": "Found",
      "description": "请求的资源临时位于不同的 URL。"
    },
    "304": {
      "phrase": "Not Modified",
      "description": "资源未被修改。"
    },
    "307": {
      "phrase": "Temporary Redirect",
      "description": "临时重定向，方法不得改变。"
    },
    "308": {
      "phrase": "Permanent Redirect",
      "description": "永久重定向，方法不得改变。"
    },
    "400": {
      "phrase": "Bad Request",
      "description": "服务器无法处理请求，因为客户端错误。"
    },
    "401": {
      "phrase": "Unauthorized",
      "description": "需要身份验证。"
    },
    "403": {
      "phrase": "Forbidden",
      "description": "服务器理解请求但拒绝执行。"
    },
    "404": {
      "phrase": "Not Found",
      "description": "找不到请求的资源。"
    },
    "405": {
      "phrase": "Method Not Allowed",
      "description": "请求方法不被允许。"
    },
    "408": {
      "phrase": "Request Timeout",
      "description": "服务器等待请求超时。"
    },
    "409": {
      "phrase": "Conflict",
      "description": "请求与服务器当前状态冲突。"
    },
    "410": {
      "phrase": "Gone",
      "description": "资源已永久不可用。"
    },
    "422": {
      "phrase": "Unprocessable Entity",
      "description": "请求格式正确，但语义错误无法处理。"
    },
    "429": {
      "phrase": "Too Many Requests",
      "description": "请求频率过高，触发限流。"
    },
    "500": {
      "phrase": "Internal Server Error",
      "description": "服务器遇到意外情况，无法完成请求。"
    },
    "501": {
      "phrase": "Not Implemented",
      "description": "服务器不支持完成请求所需的功能。"
    },
    "502": {
      "phrase": "Bad Gateway",
      "description": "服务器从上游服务器收到无效响应。"
    },
    "503": {
      "phrase": "Service Unavailable",
      "description": "服务器暂时无法处理请求。"
    },
    "504": {
      "phrase": "Gateway Timeout",
      "description": "服务器未及时收到上游服务器的响应。"
    },
    "507": {
      "phrase": "Insufficient Storage",
      "description": "服务器存储空间不足。"
    }
  }
}